<Window x:Class="FolderFlow.Views.InitialScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrganizeME — Welcome"
        Height="380" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Image Source="pack://application:,,,/Resources/Icons/logo.png" Width="48" Height="48"
                   Margin="0,0,16,0" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Welcome to OrganizeME!" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Let's get your folder organized." FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,20" />

        <!-- Message -->
        <StackPanel Grid.Row="2">
            <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,12">
                OrganizeME found existing files in your monitored folder.
            </TextBlock>
            <TextBlock x:Name="FolderPathText" TextWrapping="Wrap" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" />
            <TextBlock TextWrapping="Wrap" FontSize="14" LineHeight="22"
                       Foreground="{StaticResource TextPrimaryBrush}">
                Would you like to organize them now?
            </TextBlock>
        </StackPanel>

        <!-- Progress (hidden until running) -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0" x:Name="ProgressPanel" Visibility="Collapsed">
            <ProgressBar x:Name="ProgressBar" Height="6" Margin="0,0,0,6"
                         Minimum="0" Maximum="100"
                         Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock x:Name="ProgressText" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SkipButton" Content="Skip" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0" Click="OnSkipClicked" />
            <Button x:Name="OrganizeButton" Content="Yes, Organize Now" Style="{StaticResource PrimaryButton}"
                    Click="OnOrganizeClicked" />
        </StackPanel>
    </Grid>
</Window>
