<Window x:Class="FolderFlow.Views.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Feedback" Height="480" Width="500"
        MinHeight="480" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Send Feedback" Style="{StaticResource HeaderText}" Margin="0,0,0,20" />

        <!-- From -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="From (your email)" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBox x:Name="FromTextBox" Height="34" Padding="10,6" FontSize="13"
                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                     Background="White" Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>

        <!-- To -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="To" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBox Height="34" Padding="10,6" FontSize="13"
                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                     Background="#F0F0F0" Foreground="{StaticResource TextSecondaryBrush}"
                     Text="adeepanethwedage10171@gmail.com" IsReadOnly="True" />
        </StackPanel>

        <!-- Subject -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Subject" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBox x:Name="SubjectTextBox" Height="34" Padding="10,6" FontSize="13"
                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                     Background="White" Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>

        <!-- Body -->
        <DockPanel Grid.Row="4" Margin="0,0,0,16">
            <TextBlock DockPanel.Dock="Top" Text="Message" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4" />
            <TextBox x:Name="BodyTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                     Padding="10,8" FontSize="13"
                     BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                     Background="White" Foreground="{StaticResource TextPrimaryBrush}"
                     VerticalScrollBarVisibility="Auto" MinHeight="90" />
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"
                    Click="OnCancelClicked" />
            <Button x:Name="SendButton" Content="Send Feedback" Style="{StaticResource PrimaryButton}"
                    Click="OnSendClicked" />
        </StackPanel>
    </Grid>
</Window>
