<Window x:Class="FolderFlow.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available — OrganizeME"
        Height="520" Width="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🎉" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="SubtitleText" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,16" />

        <!-- Release Notes -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ReleaseNotesText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="20"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </ScrollViewer>
        </Border>

        <!-- Progress bar (hidden until downloading) -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="3"
                     Height="6" Margin="0,0,0,8"
                     Minimum="0" Maximum="100"
                     Visibility="Collapsed"
                     Foreground="{StaticResource PrimaryBrush}" />

        <!-- Status text + buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText" Grid.Column="0"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="LaterButton" Content="Later"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Click="OnLaterClicked" />
                <Button x:Name="DownloadButton" Content="⬇ Download &amp; Install"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnDownloadClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
